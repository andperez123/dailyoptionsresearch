OPENAI_API_KEY=sk-your-openai-key-here
FINNHUB_API_KEY=your-finnhub-key-here
ODDS_API_KEY=your-odds-api-key-here

# Optional overrides
# API_SECRET=your-local-secret
# VITE_API_SECRET=your-local-secret
# DATABASE_PATH=./data/briefings.db          # Railway: /data/briefings.db (mount volume at /data)
# ALLOWED_ORIGINS=https://your-domain.com    # extra CORS origins (comma-separated)
# OPENAI_MODEL_MINI=gpt-4o-mini
# OPENAI_MODEL=gpt-4o
# NEWS_SCAN_INTERVAL_MINUTES=15
# MARKET_SCAN_INTERVAL_MINUTES=10
# DEEP_DIVE_CACHE_MINUTES=15
# DAILY_BRIEFING_HOUR=8
# MINIMUM_WIRE_IMPACT_SCORE=5
# MINIMUM_WIRE_CONFIDENCE_SCORE=5
